digraph ARCPJobLifecycle {
  rankdir=LR;
  bgcolor="transparent";
  compound=true;
  fontname="Helvetica";
  splines=spline;
  nodesep=0.32;
  ranksep=0.55;
  pad="0.35,0.25";

  node [
    shape=box,
    style="rounded,filled",
    fillcolor="#334155",
    color="#475569",
    fontname="Helvetica",
    fontsize=11,
    fontcolor="#F1F5F9",
    margin="0.22,0.11",
    penwidth=1.0
  ];

  edge [
    fontname="Helvetica",
    fontsize=9,
    fontcolor="#94A3B8",
    color="#64748B",
    penwidth=1.1,
    arrowsize=0.75,
    arrowhead=vee
  ];

  Submit [
    label=<<FONT POINT-SIZE="12"><B>job.submit</B></FONT>>,
    fillcolor="#3B82F6", color="#2563EB",
    fontcolor="white", penwidth=1.4
  ];

  subgraph cluster_states {
    label=<<TABLE BORDER="0" CELLBORDER="0" CELLPADDING="0" CELLSPACING="0"><TR><TD COLSPAN="3" HEIGHT="8"></TD></TR><TR><TD WIDTH="8"></TD><TD><FONT POINT-SIZE="12"><B>Job states (§7.3)</B></FONT></TD><TD WIDTH="8"></TD></TR></TABLE>>;
    style="rounded,filled";
    fillcolor="#0F172A";
    color="#334155";
    fontname="Helvetica";
    fontcolor="#94A3B8";
    margin=14;
    labeljust=l;
    penwidth=1.0;

    Pending [label="pending"];

    Running [
      label=<<FONT POINT-SIZE="12"><B>running</B></FONT>>,
      fillcolor="#F59E0B", color="#D97706",
      fontcolor="white", penwidth=1.4
    ];
  }

  subgraph cluster_terminal {
    label=<<TABLE BORDER="0" CELLBORDER="0" CELLPADDING="0" CELLSPACING="0"><TR><TD COLSPAN="3" HEIGHT="8"></TD></TR><TR><TD WIDTH="8"></TD><TD><FONT POINT-SIZE="12"><B>terminal final_status</B></FONT></TD><TD WIDTH="8"></TD></TR></TABLE>>;
    style="rounded,filled";
    fillcolor="#1E293B";
    color="#334155";
    fontname="Helvetica";
    fontcolor="#94A3B8";
    margin=14;
    labeljust=l;
    penwidth=1.0;

    Success   [label="success"];
    ErrorEnd  [label="error"];
    Cancelled [label="cancelled"];
    TimedOut  [label="timed_out"];
  }

  edge [color="#94A3B8", penwidth=1.2];
  Submit  -> Pending [label="job.accepted"];
  Pending -> Running [label="status"];
  Running -> Success [label="job.result"];

  edge [color="#475569", penwidth=1.0];
  Running -> ErrorEnd  [label="job.error"];
  Running -> Cancelled [label="job.cancel +\n30s grace"];
  Running -> TimedOut  [label="max_runtime_sec"];

  Running -> Submit [
    style=dashed, color="#F472B6", penwidth=1.1,
    constraint=false,
    label=<<FONT COLOR="#F472B6">job.event[…]</FONT>>, fontsize=9
  ];
}
